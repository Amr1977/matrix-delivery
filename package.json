{
  "name": "matrix-heroes",
  "version": "1.0.0",
  "description": "Matrix Heroes - P2P Delivery & Ride-Hailing Platform",
  "scripts": {
    "test": "node scripts/run-tests.js",
    "test:all": "node scripts/run-tests.js",
    "test:api": "jest tests/map-location-api-tests.js --verbose --testTimeout=30000",
    "test:e2e": "cucumber-js tests/features --format summary --format json:test-results.json",
    "test:smoke": "node tests/smoke-health.js",
    "test:health": "node tests/smoke-health.js",
    "test:map": "cucumber-js --tags \"@map-location-picker\"",
    "test:auth": "cucumber-js --tags \"@authentication\"",
    "test:orders": "cucumber-js --tags \"@orders\"",
    "test:bidding": "cucumber-js --tags \"@bidding\"",
    "test:debug": "set HEADLESS=false&& set SLOWMO=100&& cucumber-js",
    "test:headed": "set HEADLESS=false&& cucumber-js",
    "test:report": "node tests/utils/generate-report.js",
    "pretest": "node tests/utils/cleanup.js",
    "test:pre-commit": "npm run test && echo '✅ All tests passed!'",
    "test:ci": "CI=true npm run test:all",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "build": "cd frontend && npm run build",
    "start": "cd backend && node server.js",
    "dev": "cd backend && npm run dev"
  },
  "husky": {
    "hooks": {
      "pre-commit": "npm run test:smoke && npm run test:api",
      "pre-push": "npm run test:all"
    }
  },
  "jest": {
    "testEnvironment": "node",
    "testTimeout": 30000,
    "testMatch": [
      "<rootDir>/tests/**/*.test.js",
      "<rootDir>/tests/**/*.spec.js"
    ],
    "collectCoverageFrom": [
      "**/*.{js,jsx}",
      "!**/node_modules/**",
      "!**/build/**",
      "!**/tests/**"
    ],
    "coverageReporters": [
      "text",
      "lcov",
      "html"
    ],
    "coverageDirectory": "coverage",
    "coverageThreshold": {
      "global": {
        "branches": 70,
        "functions": 70,
        "lines": 70,
        "statements": 70
      }
    }
  },
  "devDependencies": {
    "@cucumber/cucumber": "^12.2.0",
    "@playwright/test": "^1.56.1",
    "axios": "^1.13.2",
    "chai": "^4.5.0",
    "dotenv": "^16.6.1",
    "eslint": "^8.50.0",
    "husky": "^8.0.0",
    "jest": "^29.7.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.16.3",
    "playwright": "^1.40.0",
    "puppeteer": "^21.11.0",
    "supertest": "^6.3.4"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Amr1977/matrix-delivery.git"
  },
  "keywords": [
    "delivery",
    "ride-hailing",
    "transportation",
    "marketplace",
    "p2p",
    "logistics",
    "mobility",
    "heroes"
  ],
  "author": "Amr1977",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/Amr1977/matrix-delivery/issues"
  },
  "homepage": "https://github.com/Amr1977/matrix-delivery#readme",
  "dependencies": {
    "@capacitor/android": "^7.4.4",
    "@capacitor/cli": "^7.4.4",
    "@capacitor/core": "^7.4.4",
    "@paypal/checkout-server-sdk": "^1.0.3",
    "@sentry/node": "^10.27.0"
  }
}
