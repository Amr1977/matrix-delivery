{
  "name": "matrix-heroes",
  "version": "1.0.0",
  "description": "Matrix Heroes - P2P Delivery & Ride-Hailing Platform",
  "private": true,
  "workspaces": ["backend"],
  "scripts": {
    "test": "npm run test:backend",
    "test:all": "npm run test:backend && npm run test:frontend:ci && npm run test:e2e",
    "test:backend": "jest tests/unit --verbose",
    "test:frontend": "cd frontend && npm test -- --watchAll=false --passWithNoTests",
    "test:frontend:ci": "cd frontend && CI=true npm test -- --coverage --passWithNoTests",
    "test:api": "jest tests/map-location-api.test.js --verbose --testTimeout=30000",
    "test:e2e": "cross-env NODE_ENV=testing cucumber-js -c tests/cucumber.config.js",
    "test:bdd:api": "cross-env NODE_ENV=testing TEST_MODE=api cucumber-js --profile core",
    "test:bdd:e2e": "cross-env NODE_ENV=testing TEST_MODE=e2e cucumber-js --profile core",
    "test:bdd:lifecycle": "npm run test:bdd:e2e -- --tags \"@order_lifecycle\"",
    "test:smoke": "node tests/smoke-health.js",
    "test:health": "node tests/smoke-health.js",
    "test:map": "cucumber-js --tags \"@map-location-picker\"",
    "test:auth": "cucumber-js --tags \"@authentication\"",
    "test:orders": "cucumber-js --tags \"@orders\"",
    "test:bidding": "cucumber-js --tags \"@bidding\"",
    "test:debug": "set HEADLESS=false&& set SLOWMO=100&& cucumber-js",
    "test:headed": "set HEADLESS=false&& cucumber-js",
    "test:report": "node tests/utils/generate-report.js",
    "test:quick": "npm run test:backend",
    "test:watch": "cd backend && npm test -- --watch",
    "test:build": "cd frontend && npm run test:build",
    "test:build:quick": "cd frontend && npm run test:build:quick",
    "pretest": "node tests/utils/cleanup.js",
    "test:pre-commit": "npm run test && echo '✅ All tests passed!'",
    "test:ci": "CI=true npm run test:all",
    "pre-deploy": "npm run test:backend && npm run test:frontend:ci && npm run test:build && echo '✅ All pre-deployment checks passed! Ready to deploy.'",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "build": "cd frontend && npm run build",
    "start": "npm --workspace backend start",
    "dev": "cd backend && npm run dev",
    "logs:sync": "node scripts/sync-production-logs.js",
    "logs:analyze": "node scripts/log-analyzer.js",
    "logs:watch": "node scripts/log-watcher.js",
    "logs:watch:start": "pm2 start scripts/log-watcher.js --name log-watcher",
    "logs:watch:stop": "pm2 stop log-watcher",
    "logs:watch:status": "pm2 status log-watcher",
    "logs:watch:restart": "pm2 restart log-watcher",
    "deploy": "pwsh scripts/deploy.ps1",
    "deploy:backend": "pwsh scripts/deploy.ps1 -Target backend",
    "deploy:frontend": "pwsh scripts/deploy.ps1 -Target frontend",
    "deploy:skip-tests": "pwsh scripts/deploy.ps1 -SkipTests",
    "deploy:backend:skip-tests": "pwsh scripts/deploy.ps1 -Target backend -SkipTests",
    "prepare": "node -e \"process.env.CI || require('husky').install()\""
  },
  "jest": {
    "testEnvironment": "node",
    "testTimeout": 30000,
    "testMatch": [
      "<rootDir>/tests/**/*.test.js",
      "<rootDir>/tests/**/*.start.js",
      "<rootDir>/tests/**/*.spec.js",
      "<rootDir>/tests/**/*.test.ts",
      "<rootDir>/tests/**/*.spec.ts"
    ],
    "transform": {
      "^.+\\.(ts|tsx)$": "ts-jest",
      "^.+\\.(js|jsx)$": "babel-jest"
    },
    "collectCoverageFrom": [
      "**/*.{js,jsx}",
      "!**/node_modules/**",
      "!**/build/**",
      "!**/tests/**"
    ],
    "coverageReporters": [
      "text",
      "lcov",
      "html"
    ],
    "coverageDirectory": "coverage",
    "coverageThreshold": {
      "global": {
        "branches": 70,
        "functions": 70,
        "lines": 70,
        "statements": 70
      }
    }
  },
  "devDependencies": {
    "@cucumber/cucumber": "^12.2.0",
    "@playwright/test": "^1.56.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.0.3",
    "axios": "^1.13.2",
    "bcryptjs": "^3.0.3",
    "chai": "^4.5.0",
    "cross-env": "^10.1.0",
    "dotenv": "^16.6.1",
    "eslint": "^8.50.0",
    "fast-check": "^4.5.3",
    "husky": "^8.0.0",
    "jest": "^29.7.0",
    "jsonwebtoken": "^9.0.2",
    "lint-staged": "^16.2.7",
    "npm-run-all": "^4.1.5",
    "pg": "^8.16.3",
    "playwright": "^1.40.0",
    "prettier": "^3.7.4",
    "puppeteer": "^21.11.0",
    "socket.io-client": "^4.8.3",
    "supertest": "^6.3.4",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Amr1977/matrix-delivery.git"
  },
  "keywords": [
    "delivery",
    "ride-hailing",
    "transportation",
    "marketplace",
    "p2p",
    "logistics",
    "mobility",
    "heroes"
  ],
  "author": "Amr1977",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/Amr1977/matrix-delivery/issues"
  },
  "homepage": "https://github.com/Amr1977/matrix-delivery#readme",
  "dependencies": {
    "@capacitor/android": "^7.4.4",
    "@capacitor/cli": "^7.4.4",
    "@capacitor/core": "^7.4.4",
    "@paypal/checkout-server-sdk": "^1.0.3",
    "eslint-plugin-security": "^3.0.1",
    "firebase": "^12.7.0",
    "react-router-dom": "^7.12.0"
  }
}
