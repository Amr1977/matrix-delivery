modules = ["nodejs-20", "web"]
[agent]
expertMode = true

[env]
NODE_ENV = "production"

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "git commit"
mode = "sequential"
author = 53683379

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "git add . && git commit -m \"replit commit\""

[[workflows.workflow]]
name = "start backend"
mode = "sequential"
author = 53683379

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd backend && npm install && npm start"

[[workflows.workflow]]
name = "git pull"
mode = "sequential"
author = 53683379

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "git pull origin master"

[[workflows.workflow]]
name = "git status"
mode = "sequential"
author = 53683379

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "git status"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Backend Server"

[[workflows.workflow]]
name = "Backend Server"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd backend && npx cross-env DOTENV_CONFIG_PATH=.env.production PORT=5000 node -r dotenv/config server.js"
waitForPort = 5000

[deployment]
run = ["sh", "-c", "cd backend; npm start"]
deploymentTarget = "autoscale"

[[ports]]
localPort = 5000
externalPort = 80
