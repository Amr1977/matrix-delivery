{
  "name": "matrix-heroes-frontend",
  "version": "1.0.0",
  "private": true,
  "dependencies": {
    "@mapbox/polyline": "^1.2.1",
    "firebase": "^10.7.1",
    "leaflet": "^1.9.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-google-recaptcha": "^3.1.0",
    "react-hook-form": "^7.66.0",
    "react-leaflet": "^4.2.1",
    "react-scripts": "5.0.1",
    "recharts": "^2.12.0",
    "socket.io-client": "^4.8.1"
  },
  "scripts": {
    "dev": "node ../../start-dev.js",
    "dev:stop": "node ../../stop-dev.js",
    "start": "react-scripts start",
    "build": "react-scripts build",
    "build:dev": "node -e \"require('fs').copyFileSync('.env.develop', '.env')\" && set REACT_APP_ENV=development && react-scripts build",
    "build:staging": "node -e \"require('fs').copyFileSync('.env.staging', '.env')\" && set REACT_APP_ENV=staging && react-scripts build",
    "build:test": "node -e \"require('fs').copyFileSync('.env.test', '.env')\" && set REACT_APP_ENV=test && react-scripts build",
    "build:prod": "node -e \"require('fs').copyFileSync('.env.production', '.env')\" && cross-env REACT_APP_ENV=production DISABLE_ESLINT_PLUGIN=true react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject"
  },
  "eslintConfig": {
    "extends": [
      "react-app"
    ],
    "rules": {
      "no-unused-vars": "warn",
      "react-hooks/exhaustive-deps": "warn"
    }
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^5.16.4",
    "@testing-library/react": "^13.4.0",
    "@testing-library/user-event": "^14.4.3",
    "cross-env": "^10.1.0",
    "identity-obj-proxy": "^3.0.0",
    "jest-environment-jsdom": "^29.0.0"
  }
}
