{
  "name": "deliverhub-frontend",
  "version": "1.0.0",
  "private": true,
  "dependencies": {
    "firebase": "^10.7.1",
    "leaflet": "^1.9.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-google-recaptcha": "^3.1.0",
    "react-hook-form": "^7.66.0",
    "react-leaflet": "^4.2.1",
    "react-scripts": "5.0.1",
    "socket.io-client": "^4.8.1"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "build:dev": "cp .env.develop .env && export REACT_APP_ENV=development && react-scripts build",
    "build:staging": "cp .env.staging .env && export REACT_APP_ENV=staging && react-scripts build",
    "build:test": "cp .env.test .env && export REACT_APP_ENV=test && react-scripts build",
    "build:prod": "cp .env.production .env && export REACT_APP_ENV=production && react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject"
  },
  "eslintConfig": {
    "extends": [
      "react-app"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
