# Environment-specific configuration files:
# - .env.develop (for development environment)
# - .env.staging (for staging environment)
# - .env.test (for test environment)
# - .env.production (for production environment)
#
# Copy this file to create environment-specific versions:
# cp .env.example .env.develop
# cp .env.example .env.staging
# cp .env.example .env.testing
# cp .env.example .env.production
#
# Each environment should have its own API URL and reCAPTCHA keys!

# API URL for the backend service
REACT_APP_API_URL=

# Environment identifier (development, staging, production, test)
REACT_APP_ENV=development

# reCAPTCHA site key for this environment
REACT_APP_RECAPTCHA_SITE_KEY=

# WhatsApp admin number for verification requests
REACT_APP_WHATSAPP_ADMIN_NUMBER=00201094450141

OSRM_SERVER_URL=http://router.project-osrm.org

# Cryptocurrency Payment Configuration
REACT_APP_ESCROW_CONTRACT_ADDRESS=0xYOUR_DEPLOYED_ESCROW_CONTRACT
REACT_APP_BLOCKCHAIN_NETWORK=polygon
REACT_APP_BLOCKCHAIN_CHAIN_ID=137
