# Environment-specific configuration files:
# - .env.develop (for development environment)
# - .env.staging (for staging environment)
# - .env.test (for test environment)
# - .env.production (for production environment)
#
# Copy this file to create environment-specific versions:
# cp .env.example .env.develop
# cp .env.example .env.staging
# cp .env.example .env.test
# cp .env.example .env.production
#
# Each environment should have its own database!

# Server Configuration
NODE_ENV=production
PORT=5000
HOST=0.0.0.0

# Database Configuration (PostgreSQL)
# IMPORTANT: Use different database names for each environment!
DB_HOST=localhost
DB_PORT=5432
DB_NAME=matrix_delivery_production  # Change this for each environment
DB_USER=postgres
DB_PASSWORD=your_db_password_here

# JWT Configuration (CRITICAL - Generate strong secret!)
JWT_SECRET=your_jwt_secret_here

# CORS Configuration
CORS_ORIGIN=https://matrix-delivery.oldantique50.com,https://matrix-delivery.web.app

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info

# reCAPTCHA Configuration
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_here
RECAPTCHA_SITE_KEY=your_recaptcha_site_key_here

# WhatsApp Admin Configuration
WHATSAPP_ADMIN_NUMBER=00201094450141
