# ============================================================================
# Matrix Delivery Backend Environment Configuration Template
# Copy this file to .env.production and fill in the actual values
# DO NOT commit the actual .env files to git!
# ============================================================================

# ============================================================================
# SECURITY SECRETS (MUST BE ROTATED BEFORE PRODUCTION)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ============================================================================

JWT_SECRET=GENERATE_NEW_64_CHAR_HEX_STRING
JWT_REFRESH_SECRET=GENERATE_NEW_64_CHAR_HEX_STRING
ENCRYPTION_KEY=GENERATE_NEW_64_CHAR_HEX_STRING

# Token expiration
TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d
BCRYPT_ROUNDS=12

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================

NODE_ENV=production
PORT=5000
HOST=0.0.0.0

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

DB_HOST=localhost
DB_PORT=5432
DB_NAME=matrix_delivery_prod
DB_USER=matrix_delivery_prod
DB_PASSWORD=GENERATE_STRONG_PASSWORD_MIN_16_CHARS
DB_SSL=true
DB_CA_CERT=/path/to/ca-certificate.crt
DB_CONNECTION_TIMEOUT=2000

# ============================================================================
# CORS CONFIGURATION (PRODUCTION ONLY - NO LOCALHOST!)
# ============================================================================

CORS_ORIGIN=https://matrix-delivery.web.app,https://matrix-delivery.firebaseapp.com
SOCKET_IO_CORS_ORIGIN=https://matrix-delivery.web.app,https://matrix-delivery.firebaseapp.com

# ============================================================================
# RATE LIMITING
# ============================================================================

RATE_LIMIT_AUTH_MAX=5
RATE_LIMIT_AUTH_WINDOW=900000
RATE_LIMIT_API_MAX=30
RATE_LIMIT_API_WINDOW=60000
RATE_LIMIT_PUBLIC_MAX=100
RATE_LIMIT_PUBLIC_WINDOW=60000

# ============================================================================
# SECURITY FEATURES
# ============================================================================

# reCAPTCHA v2 (Get from https://www.google.com/recaptcha/admin)
RECAPTCHA_SECRET_KEY=YOUR_RECAPTCHA_SECRET_KEY
RECAPTCHA_SITE_KEY=YOUR_RECAPTCHA_SITE_KEY
RECAPTCHA_ENABLED=true

# Feature flags
ENABLE_CSRF=true
ENABLE_HELMET=true
ENABLE_RATE_LIMITING=true
ENABLE_AUDIT_LOGGING=true

# ============================================================================
# BLOCKCHAIN & CRYPTOCURRENCY CONFIGURATION
# ============================================================================

# Blockchain Network (polygon, polygonMumbai for testnet)
BLOCKCHAIN_NETWORK=polygon
BLOCKCHAIN_RPC_URL=https://polygon-rpc.com
BLOCKCHAIN_CHAIN_ID=137

# Platform Wallet (receives commission)
PLATFORM_WALLET_ADDRESS=0xYOUR_PLATFORM_WALLET_ADDRESS
PLATFORM_WALLET_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_KEEP_SECURE

# Smart Contract Addresses
ESCROW_CONTRACT_ADDRESS=0xYOUR_DEPLOYED_ESCROW_CONTRACT
USDC_CONTRACT_ADDRESS=0x2791Bca1f2de4661ED88A30C99A7a9449Aa84174
USDT_CONTRACT_ADDRESS=0xc2132D05D31c914a87C6611C10748AEb04B58e8F

# Contract Deployment
DEPLOYER_PRIVATE_KEY=0xYOUR_DEPLOYER_PRIVATE_KEY
POLYGONSCAN_API_KEY=YOUR_POLYGONSCAN_API_KEY

# Gas Settings
MAX_GAS_PRICE=100
GAS_LIMIT=300000

# ============================================================================
# MONITORING & LOGGING
# ============================================================================

# Sentry (Get from https://sentry.io)
SENTRY_DSN=https://YOUR_SENTRY_DSN@sentry.io/PROJECT_ID
LOG_LEVEL=info

# ============================================================================
# EMAIL SERVICE
# ============================================================================

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password
EMAIL_FROM=noreply@matrix-delivery.com

# ============================================================================
# EXTERNAL SERVICES
# ============================================================================

# Firebase Admin SDK
FIREBASE_PROJECT_ID=matrix-delivery
FIREBASE_PRIVATE_KEY=YOUR_FIREBASE_PRIVATE_KEY
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@matrix-delivery.iam.gserviceaccount.com

# Google Maps & OSRM
GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY
OSRM_SERVER_URL=http://router.project-osrm.org

# WhatsApp Notifications
WHATSAPP_ADMIN_NUMBER=00201094450141

# ============================================================================
# FILE UPLOAD
# ============================================================================

MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp
UPLOAD_PATH=/var/www/matrix-delivery/uploads

# ============================================================================
# FRONTEND URL
# ============================================================================

FRONTEND_URL=https://matrix-delivery.web.app
