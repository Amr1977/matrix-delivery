{
  "name": "matrix-delivery-backend",
  "version": "1.0.0",
  "description": "Matrix Delivery Backend API - Production Grade with PostgreSQL",
  "main": "server.js",
  "author": "Amr1977",
  "license": "MIT",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "prod": "cross-env NODE_ENV=production node server.js",
    "test": "jest --coverage --testPathPattern='tests/(unit|integration/(auth|health))' --maxWorkers=50%",
    "test:unit": "jest --testPathPattern=tests/unit --maxWorkers=50%",
    "test:integration": "jest --testPathPattern=tests/integration --runInBand",
    "test:integration:fast": "jest --testPathPattern='tests/integration/(auth|health)' --maxWorkers=50%",
    "test:integration:db": "jest --testPathPattern=tests/integration/database --runInBand --maxWorkers=1",
    "test:all": "npm run test:unit && npm run test:integration:fast && npm run test:integration:db",
    "test:watch": "jest --watch --testPathPattern='tests/(unit|integration/(auth|health))'",
    "test:coverage": "jest --coverage --testPathPattern='tests/(unit|integration)'",
    "test:bdd": "cross-env NODE_ENV=testing cucumber-js --exit",
    "test:bdd:report": "cross-env NODE_ENV=testing cucumber-js --exit --format html:reports/cucumber-report.html",
    "lint": "eslint ."
  },
  "dependencies": {
    "@paypal/checkout-server-sdk": "^1.0.3",
    "@sentry/node": "^10.27.0",
    "@sentry/profiling-node": "^10.27.0",
    "@types/express": "^5.0.6",
    "@types/node": "^24.10.1",
    "axios": "^1.13.1",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "csurf": "^1.11.0",
    "ethers": "^6.9.0",
    "express": "^4.18.2",
    "express-rate-limit": "^7.5.1",
    "express-validator": "^7.3.1",
    "fluent-ffmpeg": "^2.1.3",
    "geolib": "^3.3.4",
    "helmet": "^7.2.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "nodemailer": "^7.0.11",
    "pg": "^8.11.3",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.35.1",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.1",
    "stripe": "^20.0.0",
    "typescript": "^5.9.3",
    "winston": "^3.18.3",
    "winston-daily-rotate-file": "^4.7.1"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.28.5",
    "@cucumber/cucumber": "^12.3.0",
    "@nomicfoundation/hardhat-chai-matchers": "^2.1.0",
    "@nomicfoundation/hardhat-ethers": "^3.1.2",
    "@nomicfoundation/hardhat-network-helpers": "^1.1.2",
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "@nomicfoundation/hardhat-verify": "^2.1.3",
    "@openzeppelin/contracts": "^5.4.0",
    "@typechain/ethers-v6": "^0.5.1",
    "@typechain/hardhat": "^9.1.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/chai": "^4.3.20",
    "@types/jest": "^30.0.0",
    "@types/mocha": "^9.1.1",
    "@types/supertest": "^6.0.3",
    "babel-jest": "^30.2.0",
    "bcryptjs": "^3.0.3",
    "chai": "^4.5.0",
    "cross-env": "^7.0.3",
    "dotenv": "^17.2.3",
    "eslint": "^8.54.0",
    "hardhat": "^2.19.5",
    "hardhat-gas-reporter": "^1.0.10",
    "jest": "^29.7.0",
    "js-yaml": "^4.1.1",
    "nodemon": "^3.0.2",
    "sinon": "^21.0.0",
    "socket.io-client": "^4.8.1",
    "solidity-coverage": "^0.8.16",
    "supertest": "^6.3.4",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typechain": "^8.3.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "type": "commonjs"
}
