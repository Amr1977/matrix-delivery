{
    "name":  "matrix-delivery-backend",
    "version":  "1.0.0",
    "description":  "Matrix Delivery Backend API - Production Grade with PostgreSQL",
    "main":  "server.js",
    "author":  "Amr1977",
    "license":  "MIT",
    "scripts":  {
                    "start":  "node server.js",
                    "predev":  "redis-server --daemonize yes 2\u003e/dev/null || wsl sudo service redis-server start 2\u003e/dev/null || echo \u0027Redis start skipped\u0027",
                    "dev":  "cross-env NODE_OPTIONS=\"--max-old-space-size=4096\" nodemon server.js",
                    "prod":  "cross-env NODE_OPTIONS=\"--max-old-space-size=4096\" NODE_ENV=production node server.js",
                    "test":  "cross-env NODE_OPTIONS=\"--max-old-space-size=4096\" jest --coverage --maxWorkers=50%",
                    "test:unit":  "cross-env NODE_OPTIONS=\"--max-old-space-size=4096\" jest --testPathPattern=__tests__ --maxWorkers=50%",
                    "test:integration":  "cross-env NODE_OPTIONS=\"--max-old-space-size=4096\" jest --testPathPattern=__tests__ --runInBand",
                    "test:integration:fast":  "cross-env NODE_OPTIONS=\"--max-old-space-size=4096\" jest --testPathPattern=__tests__ --maxWorkers=50%",
                    "test:integration:db":  "cross-env NODE_OPTIONS=\"--max-old-space-size=4096\" jest --testPathPattern=__tests__ --runInBand --maxWorkers=1",
                    "test:all":  "npm run test:unit",
                    "test:watch":  "jest --watch",
                    "test:coverage":  "jest --coverage",
                    "test:bdd":  "cross-env NODE_ENV=testing cucumber-js --exit",
                    "test:bdd:lifecycle":  "cross-env NODE_ENV=testing cucumber-js ../tests/features/core/order_lifecycle.feature --exit",
                    "test:bdd:report":  "cross-env NODE_ENV=testing cucumber-js --exit --format html:reports/cucumber-report.html",
                    "lint":  "eslint .",
                    "users:backup":  "node scripts/user-backup-restore.js backup",
                    "users:restore":  "node scripts/user-backup-restore.js restore",
                    "users:list":  "node scripts/user-backup-restore.js list-backups",
                    "users:compare":  "node scripts/user-backup-restore.js compare",
                    "db:clone":  "node scripts/clone-db-from-env.js --exclude-logs --to backend/.env.develop"
                },
    "dependencies":  {
                         "@neondatabase/serverless":  "^1.0.2",
                         "@paypal/checkout-server-sdk":  "^1.0.3",
                         "@socket.io/redis-adapter":  "^8.3.0",
                         "axios":  "^1.13.2",
                         "bcryptjs":  "^3.0.3",
                         "better-sqlite3":  "^12.5.0",
                         "compression":  "^1.7.4",
                         "cookie":  "^1.1.1",
                         "cookie-parser":  "^1.4.7",
                         "cors":  "^2.8.5",
                         "cross-env":  "^7.0.3",
                         "dotenv":  "^17.2.3",
                         "ethers":  "^6.9.0",
                         "express":  "^4.18.2",
                         "express-rate-limit": "7.5.1",
                         "express-validator":  "^7.3.1",
                         "firebase-admin":  "^13.7.0",
                         "fluent-ffmpeg":  "^2.1.3",
                         "geolib":  "^3.3.4",
                         "helmet":  "^7.2.0",
                         "ioredis":  "^5.8.2",
                         "joi":  "^18.0.2",
                         "js-yaml":  "^4.1.1",
                         "jsonwebtoken":  "^9.0.2",
                         "morgan":  "^1.10.1",
                         "multer":  "^2.0.2",
                         "nodemailer":  "^6.9.16",
                         "pg":  "^8.11.3",
                         "rate-limit-redis":  "^4.3.1",
                         "sharp":  "^0.34.5",
                         "socket.io":  "^4.8.1",
                         "socket.io-client":  "^4.8.3",
                         "stripe":  "^20.0.0",
                         "swagger-jsdoc":  "^6.2.8",
                         "swagger-ui-express":  "^5.0.1",
                         "ts-node":  "^10.9.2",
                         "winston":  "^3.18.3",
                         "winston-daily-rotate-file":  "^4.7.1"
                     },
    "devDependencies":  {
                            "@babel/preset-env":  "^7.28.5",
                            "@cucumber/cucumber":  "^12.4.0",
                            "@nomicfoundation/hardhat-chai-matchers":  "^2.1.0",
                            "@nomicfoundation/hardhat-ethers":  "^3.1.2",
                            "@nomicfoundation/hardhat-network-helpers":  "^1.1.2",
                            "@nomicfoundation/hardhat-toolbox":  "^4.0.0",
                            "@nomicfoundation/hardhat-verify":  "^2.1.3",
                            "@openzeppelin/contracts":  "^5.4.0",
                            "@typechain/ethers-v6":  "^0.5.1",
                            "@typechain/hardhat":  "^9.1.0",
                            "@types/bcryptjs":  "^2.4.6",
                            "@types/chai":  "^4.3.20",
                            "@types/express":  "^5.0.6",
                            "@types/jest":  "^30.0.0",
                            "@types/mocha":  "^9.1.1",
                            "@types/node":  "^25.0.3",
                            "@types/pg":  "^8.16.0",
                            "@types/supertest":  "^6.0.3",
                            "babel-jest":  "^30.2.0",
                            "chai":  "^4.5.0",
                            "eslint":  "^8.54.0",
                            "fast-check":  "^4.5.3",
                            "hardhat":  "^2.19.5",
                            "hardhat-gas-reporter":  "^1.0.10",
                            "jest":  "^29.7.0",
                            "js-yaml":  "^4.1.1",
                            "nodemon":  "^3.0.2",
                            "sinon":  "^21.0.0",
                            "solidity-coverage":  "^0.8.16",
                            "supertest":  "^6.3.4",
                            "ts-jest":  "^29.4.6",
                            "typechain":  "^8.3.2",
                            "typescript":  "^5.9.3"
                        },
    "engines":  {
                    "node":  "\u003e=18.0.0",
                    "npm":  "\u003e=9.0.0"
                },
    "type":  "commonjs"
}

