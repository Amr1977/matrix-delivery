# Paymob Payment Integration - Environment Variables

# Get these from your Paymob dashboard: https://accept.paymob.com/portal2/en/settings

# API Key (Required)
PAYMOB_API_KEY=your_api_key_here

# Integration IDs (Required)
# Card Integration ID - for credit/debit card payments
PAYMOB_INTEGRATION_ID_CARD=your_card_integration_id

# Wallet Integration ID - for mobile wallet payments (Vodafone, Orange, Etisalat)
PAYMOB_INTEGRATION_ID_WALLET=your_wallet_integration_id

# Iframe ID (Required)
# Used to display the payment form
PAYMOB_IFRAME_ID=your_iframe_id

# HMAC Secret (Required for production)
# Used to verify webhook callbacks
PAYMOB_HMAC_SECRET=your_hmac_secret

# Frontend URL (for redirects)
FRONTEND_URL=https://matrix-delivery.web.app

# Example values (DO NOT USE IN PRODUCTION):
# PAYMOB_API_KEY=ZXlKaGJHY2lPaUpJVXpVeE1pSXNJblI1Y0NJNklrcFhWQ0o5
# PAYMOB_INTEGRATION_ID_CARD=123456
# PAYMOB_INTEGRATION_ID_WALLET=123457
# PAYMOB_IFRAME_ID=123458
# PAYMOB_HMAC_SECRET=A1B2C3D4E5F6G7H8I9J0K1L2M3N4O5P6
