# Environment
NODE_ENV=production
PORT=5000

# Redis (for Socket.IO adapter in PM2 cluster mode)
# If Redis has a password, use: redis://:YOUR_PASSWORD@localhost:6379
REDIS_URL=redis://localhost:6379

# Database (PRODUCTION)
DATABASE_URL='postgresql://neondb_owner:***REDACTED***@ep-shy-tooth-ab6w37t9-pooler.eu-west-2.aws.neon.tech/matrix_delivery_production?sslmode=require&channel_binding=require'


# Security Secrets
JWT_SECRET=***REDACTED***
JWT_REFRESH_SECRET=***REDACTED***
ENCRYPTION_KEY=***REDACTED***

# CORS (NO LOCALHOST!)
CORS_ORIGIN=https://matrix-delivery.web.app,https://matrix-delivery.firebaseapp.com,https://matrix-delivery-api-gc.mywire.org,https://matrix-delivery-api.mywire.org
SOCKET_IO_CORS_ORIGIN=https://matrix-delivery.web.app,https://matrix-delivery.firebaseapp.com,https://matrix-delivery-api-gc.mywire.org,https://matrix-delivery-api.mywire.org

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info

# reCAPTCHA Configuration (using production keys)
RECAPTCHA_SECRET_KEY=6Le45H0sAAAAAKyiMqbKzDOSvInJCC8Vmd7ISbZH
RECAPTCHA_SITE_KEY=6Le45H0sAAAAADBEQgdEraqH-G5iORVnbLLZe8fB

OSRM_SERVER_URL=http://router.project-osrm.org

FRONTEND_URL=https://matrix-delivery.web.app

STRIPE_SECRET_KEY=***REDACTED***

SENTRY_DSN=https://1db9b86d461b25f6857f2c649f5a0307@o108586.ingest.us.sentry.io/4510462753046528

# Security Features
RECAPTCHA_ENABLED=true
ENABLE_CSRF=true
ENABLE_HELMET=true
ENABLE_RATE_LIMITING=true
ENABLE_AUDIT_LOGGING=true

# ============================================================================
# BLOCKCHAIN & CRYPTOCURRENCY CONFIGURATION
# ============================================================================

# Deployer wallet
DEPLOYER_PRIVATE_KEY=0x***REDACTED***

# Platform wallet (where commission goes)
PLATFORM_WALLET_ADDRESS=0xfa83394a4f3346717cfad47c27bbe66a19df1ca4
PLATFORM_WALLET_PRIVATE_KEY=0x***REDACTED***

# Blockchain Network - Polygon Mainnet
BLOCKCHAIN_NETWORK=polygon
BLOCKCHAIN_RPC_URL=https://polygon-rpc.com
BLOCKCHAIN_CHAIN_ID=137

# Token Addresses (Polygon Mainnet)
USDC_CONTRACT_ADDRESS=0x2791Bca1f2de4661ED88A30C99A7a9449Aa84174
USDT_CONTRACT_ADDRESS=0xc2132D05D31c914a87C6611C10748AEb04B58e8F

# Gas Settings
MAX_GAS_PRICE=100
GAS_LIMIT=300000

# Commission
PLATFORM_COMMISSION_RATE=0.15

# Contract Address (leave empty for now, will be filled after deployment)
ESCROW_CONTRACT_ADDRESS=0xD75CD1480698576bD7c7A813207Af20a78775142


SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=quran.lights.network@gmail.com
SMTP_PASS=***REDACTED***
FROM_EMAIL=no-reply@matrix-delivery.com
EMAIL_SEND_ENABLED=true

