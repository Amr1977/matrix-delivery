# ============================================================================
# Migration Environment Configuration Template
# ============================================================================

# Firebase Admin SDK
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
FIREBASE_PROJECT_ID=matrix-delivery

# Redis connection
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=YOUR_STRONG_REDIS_PASSWORD

# Backend server IDs (comma-separated)
BACKEND_SERVER_IDS=server-1,server-2

# V2 configuration file paths
V2_BACKEND_ENV_PATH=/path/to/matrix-delivery/backend/.env
V2_AGGREGATOR_ENV_PATH=/path/to/matrix-delivery/aggregator/.env

# WebSocket port
WS_PORT=4001

# Migration log path
MIGRATION_LOG_PATH=/var/log/matrix-delivery/migration

# Directories
AGGREGATOR_DIR=/path/to/matrix-delivery/aggregator
BACKEND_DIR=/path/to/matrix-delivery/backend

# Expected healthy servers after migration (default: 1)
EXPECTED_HEALTHY_COUNT=1