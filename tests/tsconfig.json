{
    "compilerOptions": {
        "target": "ES2020",
        "module": "commonjs",
        "lib": [
            "ES2020"
        ],
        "esModuleInterop": true,
        "skipLibCheck": true,
        "strict": false,
        "resolveJsonModule": true,
        "moduleResolution": "node",
        "allowSyntheticDefaultImports": true,
        "forceConsistentCasingInFileNames": true,
        "noEmit": true,
        "types": [
            "node",
            "jest"
        ]
    },
    "include": [
        "**/*.ts",
        "**/*.js",
        "../backend/**/*.ts"
    ],
    "exclude": [
        "node_modules"
    ]
}