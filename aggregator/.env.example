# ============================================================================
# Aggregator Environment Configuration Template
# ============================================================================

# Redis connection
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=YOUR_STRONG_REDIS_PASSWORD

# WebSocket server port for frontend clients
WS_PORT=4001

# Aggregation interval in milliseconds (default 5000)
AGGREGATOR_INTERVAL_MS=5000

# Staleness threshold in milliseconds (default 90000)
STALENESS_THRESHOLD_MS=90000

# Health check timeout in milliseconds (default 2000)
HEALTH_CHECK_TIMEOUT_MS=2000

# Latency baseline in milliseconds (default 1000)
LATENCY_BASELINE_MS=1000

# Minimum score spread for normalization warning (default 0.05)
MIN_SCORE_SPREAD=0.05