# Matrix Delivery Environment Variables
DATABASE_URL=postgresql://user:password@localhost:5432/database_name
REDIS_URL=redis://localhost:6379

# Telegram Bot Configuration
# Get bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
# Your admin chat ID (get it from @userinfobot on Telegram)
TELEGRAM_ADMIN_CHAT_ID=your_admin_chat_id_here
# Secret token for webhook verification (optional but recommended)
TELEGRAM_SECRET_TOKEN=your_secret_token_here
# Admin user ID for withdrawal approvals
TELEGRAM_ADMIN_ID=admin_user_id
